# Copy to backend/.env for local dev, or set in Coolify UI

# SQLite — in Docker use volume mount /data and:
# DATABASE_URL=sqlite:////data/fakturovatko.sqlite3
DATABASE_URL=sqlite:///./data/fakturovatko.sqlite3

ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Coolify scheduled task: curl -H "X-Cron-Token: $CRON_SECRET" http://localhost:8000/internal/jobs/poll-payments
CRON_SECRET=change-me-in-production
# Druhá fáze (poll plateb / dokončení objednávky). Default v aplikaci je vypnuto; zapni až budeš chtít cron spouštět.
# CRON_POLL_PAYMENTS_ENABLED=true

# Ti.to (live token from id.tito.io)
TITO_API_KEY=
TITO_ACCOUNT_SLUG=redbutton
TITO_EVENT_SLUG=es-2026

# Allfred Workspace API
ALLFRED_API_KEY=
ALLFRED_WORKSPACE=redbuttonedu
# quickSetupClientProjectInvoice — výchozí v kódu: workspace company id 2 = Happiness at Work s.r.o. (1 = RB Associates).
# Přepiš jen pokud potřebuješ jiný vystavitel / tým / PM v Allfredu.
# ALLFRED_WORKSPACE_COMPANY_ID=2
# ALLFRED_TEAM_ID=12
# ALLFRED_PROJECT_MANAGER_ID=27
# ALLFRED_QUICK_SETUP_ERROR_EMAIL=lukas@redbuttonedu.cz
# DPH jako BigInt v Allfredu (typicky 2100 = 21 %)
ALLFRED_INVOICE_VAT_RATE=2100
# Splatnost zálohové proformy (QuickSetupInvoiceInput.due_date = issue + N dní)
# ALLFRED_PROFORMA_DUE_DAYS=14
# Minimální datum vystavení v Allfredu (když API hlásí businessLogic na issue_date)
# ALLFRED_ISSUE_DATE_NOT_BEFORE=2026-04-16
# Volitelné: QuickSetupInvoiceInput (viz introspection / scripts/allfred_introspect.py)
# Výchozí bankovní účet na dokladu: id 2 u HaW (Allfred); u RB Associates jsou jiné id.
# ALLFRED_WORKSPACE_BANK_ACCOUNT_ID=2
# SK zákazníci: doklad v EUR + ČNB + ALLFRED_WORKSPACE_BANK_ACCOUNT_ID_EUR — zapni až bude Allfred API fungovat.
# ALLFRED_SK_INVOICE_IN_EUR=false
# ALLFRED_WORKSPACE_BANK_ACCOUNT_ID_EUR=
# ALLFRED_INVOICE_SEQUENCE_ID=
# ALLFRED_VAT_REVERSE_CHARGE=true
# Stažení PDF (proforma + finální faktura): webové účty Allfredu — session cookie po POST /login (viz Equilibrium n8n)
# ALLFRED_UI_EMAIL=
# ALLFRED_UI_PASSWORD=
# Jméno kontaktu na vystavené faktuře v Allfredu (PDF), výchozí Dominik Holíček — odlišné od GMAIL_FROM_NAME
# ALLFRED_CONTACT_NAME=Dominik Holíček
# Workaround: proformy považovat za zaplacené bez paid_at v API (čárkou: id a/nebo číslo faktury). Po testu odstranit.
# ALLFRED_FAKE_PAID_PROFORMA_REFS=10,1-26-00009
# Pokud objednávka nemá ticket_unit_price_czk (staré řádky), použije se tato jednotková cena v Kč
ALLFRED_FALLBACK_UNIT_PRICE_CZK=1000

# Gmail — same OAuth app as RB Universe; refresh token pro účet s právem odesílat jako GMAIL_FROM_EMAIL
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# Odesílatel + stejné jméno/e-mail jako kontaktní osoba na Allfred dokladu
GMAIL_FROM_NAME=Tým Red Button
GMAIL_FROM_EMAIL=hello@redbuttonedu.cz

# Pipedrive
PIPEDRIVE_API_TOKEN=

# OpenData FS (SK) — API klíč z portálu FS; doplnění IČ DPH při načtení firmy z RPO (volitelné)
# OPENDATA_FS=

# Simulace „zaplacené“ proformy pro mock objednávky (mock-proforma-… v DB) — spolu s POST /internal/jobs/poll-payments
# Produkce: false. Bez skutečné proformy v Allfredovi: může být ALLFRED_API_KEY prázdný, pokud jsou jen mock objednávky.
# ALLFRED_MOCK_PAID=true
ALLFRED_MOCK_PAID=false
